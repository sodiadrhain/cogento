{
  "name": "cogento",
  "displayName": "Cogento AI Coding Agent",
  "publisher": "sodiadrhain",
  "icon": "media/icon.png",
  "description": "Open Source AI Coding Agent - VS Code Extension",
  "version": "0.1.1",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sodiadrhain/cogento"
  },
  "bugs": {
    "url": "https://github.com/sodiadrhain/cogento/issues"
  },
  "homepage": "https://github.com/sodiadrhain/cogento#readme",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cogento.start",
        "title": "Start Cogento AI Agent"
      },
      {
        "command": "cogento.openSettings",
        "title": "Open Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cogento-sidebar",
          "title": "Cogento",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cogento-sidebar": [
        {
          "type": "webview",
          "id": "cogento.chatView",
          "name": "",
          "icon": "media/icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cogento.openSettings",
          "when": "view == cogento.chatView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Cogento Settings",
      "properties": {
        "cogento.apiKeys.openai": {
          "type": "string",
          "default": "",
          "description": "OpenAI API Key for Cogento Agent"
        },
        "cogento.apiKeys.anthropic": {
          "type": "string",
          "default": "",
          "description": "Anthropic API Key for Cogento Agent"
        },
        "cogento.apiKeys.gemini": {
          "type": "string",
          "default": "",
          "description": "Google Gemini API Key for Cogento Agent"
        },
        "cogento.provider": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "anthropic",
            "gemini"
          ],
          "description": "Default LLM Provider"
        },
        "cogento.geminiModel": {
          "type": "string",
          "default": "gemini-3.1-pro-preview",
          "enum": [
            "gemini-3.1-pro-preview",
            "gemini-3-pro-preview",
            "gemini-3-flash-preview",
            "gemini-2.5-pro",
            "gemini-2.5-flash"
          ],
          "enumDescriptions": [
            "Gemini 3.1 Pro (Preview) — Latest preview, advanced reasoning and world knowledge (recommended)",
            "Gemini 3 Pro (Preview) — High quality complex reasoning model",
            "Gemini 3 Flash (Preview) — Fast throughput model with pro-level intelligence",
            "Gemini 2.5 Pro — Stable highly capable model",
            "Gemini 2.5 Flash — Stable fast model"
          ],
          "description": "Gemini model to use for code generation"
        },
        "cogento.openaiModel": {
          "type": "string",
          "default": "gpt-4o",
          "enum": [
            "gpt-4o",
            "gpt-4o-mini",
            "o3-mini",
            "gpt-4-turbo"
          ],
          "enumDescriptions": [
            "GPT-4o — Best overall coding model (recommended)",
            "GPT-4o Mini — Faster and cheaper, good for simpler tasks",
            "o3-mini — Strong reasoning, great for complex problem solving",
            "GPT-4 Turbo — Previous generation, large context window"
          ],
          "description": "OpenAI model to use for code generation"
        },
        "cogento.anthropicModel": {
          "type": "string",
          "default": "claude-sonnet-4-5",
          "enum": [
            "claude-opus-4-5",
            "claude-sonnet-4-5",
            "claude-haiku-4-5",
            "claude-3-7-sonnet-latest"
          ],
          "enumDescriptions": [
            "Claude Opus 4.5 — Most capable, best for large complex codebases",
            "Claude Sonnet 4.5 — Best balance of speed and quality (recommended)",
            "Claude Haiku 4.5 — Fastest and cheapest, good for quick edits",
            "Claude 3.7 Sonnet — Previous generation, strong coding performance"
          ],
          "description": "Anthropic model to use for code generation"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\"",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "npm-run-all": "^1.1.3",
    "prettier": "^3.8.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.42.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "openai": "^6.22.0"
  }
}
